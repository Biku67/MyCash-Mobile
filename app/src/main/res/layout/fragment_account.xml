<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="@dimen/spacing_md">

        <!-- Header -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/nav_account"
            android:textColor="@color/text_primary"
            android:textSize="@dimen/text_title"
            android:textStyle="bold"
            android:layout_marginBottom="@dimen/spacing_lg" />

        <!-- Profile Card -->
        <com.google.android.material.card.MaterialCardView
            style="@style/MyCash.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_md">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="@dimen/spacing_lg">

                <!-- Avatar -->
                <FrameLayout
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:layout_marginEnd="@dimen/spacing_md"
                    android:background="@drawable/bg_avatar">

                    <TextView
                        android:id="@+id/tvAvatar"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="B"
                        android:textColor="@color/accent_lime"
                        android:textSize="22sp"
                        android:textStyle="bold" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvProfileName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Bendahara"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_heading"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvProfileClass"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Nama Kelas"
                        android:textColor="@color/text_secondary"
                        android:textSize="@dimen/text_caption"
                        android:layout_marginTop="2dp" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Menu Section -->
        <com.google.android.material.card.MaterialCardView
            style="@style/MyCash.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_md">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:divider="@drawable/divider_subtle"
                android:showDividers="middle">

                <!-- Manajemen Siswa -->
                <LinearLayout
                    android:id="@+id/menuStudents"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="@dimen/spacing_md"
                    android:paddingEnd="@dimen/spacing_md"
                    android:background="?attr/selectableItemBackground">

                    <ImageView
                        android:layout_width="@dimen/icon_md"
                        android:layout_height="@dimen/icon_md"
                        android:src="@drawable/ic_placeholder"
                        android:layout_marginEnd="@dimen/spacing_md"
                        app:tint="@color/color_info"
                        xmlns:app="http://schemas.android.com/apk/res-auto" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/settings_students"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_body" />

                    <TextView
                        android:id="@+id/tvStudentCount"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="@color/text_tertiary"
                        android:textSize="@dimen/text_caption" />
                </LinearLayout>

                <!-- Laporan -->
                <LinearLayout
                    android:id="@+id/menuReport"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="@dimen/spacing_md"
                    android:paddingEnd="@dimen/spacing_md"
                    android:background="?attr/selectableItemBackground">

                    <ImageView
                        android:layout_width="@dimen/icon_md"
                        android:layout_height="@dimen/icon_md"
                        android:src="@drawable/ic_placeholder"
                        android:layout_marginEnd="@dimen/spacing_md"
                        app:tint="@color/color_income"
                        xmlns:app="http://schemas.android.com/apk/res-auto" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/settings_report"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_body" />
                </LinearLayout>

                <!-- Backup -->
                <LinearLayout
                    android:id="@+id/menuBackup"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="@dimen/spacing_md"
                    android:paddingEnd="@dimen/spacing_md"
                    android:background="?attr/selectableItemBackground">

                    <ImageView
                        android:layout_width="@dimen/icon_md"
                        android:layout_height="@dimen/icon_md"
                        android:src="@drawable/ic_placeholder"
                        android:layout_marginEnd="@dimen/spacing_md"
                        app:tint="@color/color_warning"
                        xmlns:app="http://schemas.android.com/apk/res-auto" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/settings_backup"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_body" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Settings Section -->
        <com.google.android.material.card.MaterialCardView
            style="@style/MyCash.Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/spacing_md">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:divider="@drawable/divider_subtle"
                android:showDividers="middle">

                <!-- Biometric -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="@dimen/spacing_md"
                    android:paddingEnd="@dimen/spacing_md">

                    <ImageView
                        android:layout_width="@dimen/icon_md"
                        android:layout_height="@dimen/icon_md"
                        android:src="@drawable/ic_placeholder"
                        android:layout_marginEnd="@dimen/spacing_md"
                        app:tint="@color/accent_lime"
                        xmlns:app="http://schemas.android.com/apk/res-auto" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/settings_biometric"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_body" />

                    <com.google.android.material.materialswitch.MaterialSwitch
                        android:id="@+id/switchBiometric"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:thumbTint="@color/accent_lime"
                        app:trackTint="@color/bg_surface_variant"
                        xmlns:app="http://schemas.android.com/apk/res-auto" />
                </LinearLayout>

                <!-- About -->
                <LinearLayout
                    android:id="@+id/menuAbout"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:paddingStart="@dimen/spacing_md"
                    android:paddingEnd="@dimen/spacing_md"
                    android:background="?attr/selectableItemBackground">

                    <ImageView
                        android:layout_width="@dimen/icon_md"
                        android:layout_height="@dimen/icon_md"
                        android:src="@drawable/ic_placeholder"
                        android:layout_marginEnd="@dimen/spacing_md"
                        app:tint="@color/text_tertiary"
                        xmlns:app="http://schemas.android.com/apk/res-auto" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/settings_about"
                        android:textColor="@color/text_primary"
                        android:textSize="@dimen/text_body" />
                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Version -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="MyCash v1.0"
            android:textColor="@color/text_tertiary"
            android:textSize="@dimen/text_caption"
            android:gravity="center"
            android:layout_marginTop="@dimen/spacing_md"
            android:layout_marginBottom="@dimen/spacing_xl" />

    </LinearLayout>
</androidx.core.widget.NestedScrollView>
