<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme - Dark -->
    <style name="Base.Theme.Mycash" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/accent_lime</item>
        <item name="colorOnPrimary">@color/text_on_accent</item>
        <item name="colorPrimaryContainer">@color/accent_lime_10</item>
        <item name="colorOnPrimaryContainer">@color/accent_lime</item>

        <item name="colorSecondary">@color/color_info</item>
        <item name="colorOnSecondary">@color/white</item>

        <item name="colorSurface">@color/bg_surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorSurfaceVariant">@color/bg_surface_variant</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary</item>

        <item name="colorError">@color/color_expense</item>

        <item name="android:colorBackground">@color/bg_primary</item>
        <item name="colorOnBackground">@color/text_primary</item>

        <item name="android:windowBackground">@color/bg_primary</item>
        <item name="android:statusBarColor">@color/bg_primary</item>
        <item name="android:navigationBarColor">@color/bg_surface</item>

        <item name="bottomNavigationStyle">@style/MyCash.BottomNav</item>
    </style>

    <style name="Theme.Mycash" parent="Base.Theme.Mycash" />

    <!-- Bottom Navigation Style -->
    <style name="MyCash.BottomNav" parent="Widget.Material3.BottomNavigationView">
        <item name="android:background">@color/bg_surface</item>
        <item name="itemIconTint">@color/bottom_nav_color</item>
        <item name="itemTextColor">@color/bottom_nav_color</item>
        <item name="itemActiveIndicatorStyle">@style/MyCash.BottomNav.ActiveIndicator</item>
    </style>

    <style name="MyCash.BottomNav.ActiveIndicator" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:color">@color/accent_lime_10</item>
    </style>

    <!-- Card Style -->
    <style name="MyCash.Card" parent="Widget.Material3.CardView.Filled">
        <item name="cardBackgroundColor">@color/bg_surface</item>
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeWidth">1dp</item>
        <item name="strokeColor">@color/border_subtle</item>
    </style>

    <!-- Stat Card (smaller radius) -->
    <style name="MyCash.StatCard" parent="MyCash.Card">
        <item name="cardCornerRadius">12dp</item>
    </style>

    <!-- Primary Button -->
    <style name="MyCash.Button.Primary" parent="Widget.Material3.Button">
        <item name="android:backgroundTint">@color/accent_lime</item>
        <item name="android:textColor">@color/text_on_accent</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <!-- Outline Button -->
    <style name="MyCash.Button.Outline" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">@color/border_medium</item>
        <item name="android:textColor">@color/text_secondary</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <!-- Input Field -->
    <style name="MyCash.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundColor">@color/bg_surface_variant</item>
        <item name="boxStrokeColor">@color/border_medium</item>
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
        <item name="hintTextColor">@color/text_secondary</item>
    </style>

    <!-- FAB Style -->
    <style name="MyCash.FAB" parent="Widget.Material3.FloatingActionButton.Primary">
        <item name="backgroundTint">@color/accent_lime</item>
        <item name="tint">@color/text_on_accent</item>
    </style>

    <!-- Chip / Badge -->
    <style name="MyCash.Badge.Income" parent="Widget.Material3.Button.TextButton">
        <item name="android:backgroundTint">@color/color_income_10</item>
        <item name="android:textColor">@color/color_income</item>
        <item name="android:textSize">11sp</item>
        <item name="cornerRadius">8dp</item>
        <item name="android:minHeight">24dp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <style name="MyCash.Badge.Expense" parent="MyCash.Badge.Income">
        <item name="android:backgroundTint">@color/color_expense_10</item>
        <item name="android:textColor">@color/color_expense</item>
    </style>

    <!-- Splash Theme -->
    <style name="Theme.Mycash.Splash" parent="Theme.Mycash">
        <item name="android:windowBackground">@color/bg_primary</item>
    </style>
</resources>